pragma solidity ^0.8.20;

contract Web3DAOPortal {
    // Tous les émojis problématiques (arbre, crochet, croix) ont été convertis en texte standard
    string public constant main = '<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Bigfoot DAO | Governance Portal</title><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:\'Segoe UI\',sans-serif;background-color:#0b0b0f;color:#fff;padding:40px 5%}header{display:flex;justify-content:space-between;align-items:center;margin-bottom:40px;border-bottom:1px solid #232330;padding-bottom:20px}.btn{padding:12px 24px;background:#0052ff;border:none;color:#fff;border-radius:25px;cursor:pointer;font-weight:700;transition:background 0.3s}.btn:hover{background:#0041cc}.dao-card{background:#121218;border:1px solid #232330;border-radius:12px;padding:30px;max-width:600px;margin:40px auto;text-align:center}h2{margin-bottom:20px;color:#0052ff}.stats{display:flex;justify-content:center;gap:40px;margin:25px 0;font-size:1.2rem;font-weight:bold}.vote-actions{display:flex;justify-content:center;gap:20px;margin-top:30px}#propDesc{font-size:1.1rem;color:#ccc;line-height:1.5}</style><script src="https://cloudflare.com"></script></head><body><header><h1>BIGFOOT-DAO</h1><button id="connectBtn" class="btn" onclick="connect()">Connect Wallet</button></header><main><div class="dao-card"><h2>Active Proposal</h2><p id="propDesc">Loading proposal data directly from Polygon Amoy...</p><div class="stats"><div style="color:#00ff88">[+] For: <span id="votesFor">0</span></div><div style="color:#ff3333">[-] Against: <span id="votesAgainst">0</span></div></div><div class="vote-actions"><button class="btn" onclick="castVote(true)">Vote FOR</button><button class="btn" style="background:#ff3333" onclick="castVote(false)">Vote AGAINST</button></div></div></main><script>let provider,signer,daoContract;const contractAddress="0x887D7cCA5b46DeE0C69fD02AFb23c660CA0dA0cD";const abi=["function proposals(uint256) view returns (string description,uint256 votesFor,uint256 votesAgainst,bool executed)","function vote(uint256,bool) external"];async function connect(){if(!window.ethereum)return alert("Web3 Wallet not detected! Install MetaMask or Rabby.");provider=new ethers.providers.Web3Provider(window.ethereum);await provider.send("eth_requestAccounts",[]);signer=provider.getSigner();const addr=await signer.getAddress();document.getElementById("connectBtn").innerText=addr.substring(0,6)+"..."+addr.substring(38);daoContract=new ethers.Contract(contractAddress,abi,signer);loadProposal()}async function loadProposal(){if(!daoContract)return;try{const prop=await daoContract.proposals(0);document.getElementById("propDesc").innerText=prop.description;document.getElementById("votesFor").innerText=prop.votesFor.toString();document.getElementById("votesAgainst").innerText=prop.votesAgainst.toString()}catch(e){console.error(e)}}async function castVote(support){if(!daoContract)return alert("Please connect your wallet first!");try{document.getElementById("propDesc").innerText="Sending transaction to Polygon...";const tx=await daoContract.vote(0,support);document.getElementById("propDesc").innerText="Waiting for block confirmation...";await tx.wait();document.getElementById("propDesc").innerText="Vote recorded successfully!";loadProposal()}catch(e){alert("Transaction failed: "+e.message);loadProposal()}}window.addEventListener(\'load\',async()=>{if(window.ethereum){provider=new ethers.providers.Web3Provider(window.ethereum);const accounts=await provider.listAccounts();if(accounts.length>0){connect()}}});</script></body></html>';

    function resolveMode() external pure returns (bytes32) {
        return keccak256("object");
    }
}
